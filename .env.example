# Local demo defaults. Mock mode requires no API key.
APP_ENV=local
ECE_LLM_MODE=mock
ECE_API_URL=http://localhost:8000
ECE_VECTOR_BACKEND=memory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_context_chunks
ECE_STORAGE_BACKEND=memory
ECE_SQLITE_PATH=data/state/enterprise_context_engine.db
ECE_AUTH_MODE=off
ECE_DEMO_API_KEYS=admin_user:dev-admin-key,finance_user:dev-finance-key,hr_user:dev-hr-key,engineer_user:dev-engineer-key,legal_user:dev-legal-key,intern_user:dev-intern-key

# Optional OpenAI-compatible generation settings.
# Leave these empty when using ECE_LLM_MODE=mock.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

ENABLE_RERANKING=false
DEFAULT_TOP_K=5
